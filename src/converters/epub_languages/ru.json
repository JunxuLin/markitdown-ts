{
  "_comment": "Russian EPUB language config. Chapters use 'Глава N' or 'Часть N'.",
  "chapter_patterns": [
    {
      "regex": "^Глава\\s+(\\d+)[.:\\s]*(.*)$",
      "flags": [],
      "num_group": 1,
      "rest_group": 2
    },
    {
      "regex": "^Часть\\s+(\\d+)[.:\\s]*(.*)$",
      "flags": [],
      "num_group": 1,
      "rest_group": 2
    },
    {
      "regex": "^(\\d+)\\s*[.:]\\s*(.+)$",
      "flags": [],
      "num_group": 1,
      "rest_group": 2
    }
  ],
  "front_matter_titles": [
    "Оглавление", "Содержание", "Предисловие", "Введение", "Вступление",
    "Посвящение", "Пролог", "От автора", "Об авторе"
  ],
  "back_matter_titles": [
    "Заключение", "Эпилог", "Примечания", "Послесловие", "Библиография",
    "Список литературы", "Указатель", "Приложение", "Благодарности", "Сноски"
  ],
  "skip_titles": ["Содержание", "Оглавление"]
}
